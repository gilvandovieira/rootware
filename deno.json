{
  "workspace": [
    "packages/errors",
    "packages/env",
    "packages/log",
    "packages/testing",
    "packages/http",
    "packages/cache",
    "packages/storage",
    "packages/session",
    "packages/schema",
    "packages/migrate",
    "packages/orm",
    "packages/jobs"
  ],
  "imports": {
    "@std/assert": "jsr:@std/assert@^1",
    "@rootware/errors": "./packages/errors/mod.ts",
    "@rootware/env": "./packages/env/mod.ts",
    "@rootware/log": "./packages/log/mod.ts",
    "@rootware/testing": "./packages/testing/mod.ts",
    "@rootware/http": "./packages/http/mod.ts",
    "@rootware/cache": "./packages/cache/mod.ts",
    "@rootware/storage": "./packages/storage/mod.ts",
    "@rootware/session": "./packages/session/mod.ts",
    "@rootware/schema": "./packages/schema/mod.ts",
    "@rootware/migrate": "./packages/migrate/mod.ts",
    "@rootware/migrate/postgres": "./packages/migrate/postgres/mod.ts",
    "@rootware/orm": "./packages/orm/mod.ts",
    "@rootware/orm/postgres": "./packages/orm/postgres/mod.ts",
    "@rootware/jobs": "./packages/jobs/mod.ts"
  },
  "tasks": {
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "check": "deno check packages/*/mod.ts packages/orm/postgres/mod.ts packages/migrate/postgres/mod.ts",
    "test": "deno test",
    "graph": "deno run -A scripts/check_graph.ts",
    "test:coverage": "deno test --coverage=coverage",
    "coverage:lcov": "deno coverage coverage --lcov > coverage.lcov",
    "ci": "deno task fmt:check && deno task lint && deno task check && deno task graph && deno task test",
    "ci:full": "deno task ci && deno task test:coverage && deno task publish:dry",
    "publish:dry": "deno task publish:dry:errors && deno task publish:dry:env && deno task publish:dry:log && deno task publish:dry:testing && deno task publish:dry:http && deno task publish:dry:cache && deno task publish:dry:storage && deno task publish:dry:session && deno task publish:dry:schema && deno task publish:dry:migrate && deno task publish:dry:orm && deno task publish:dry:jobs",
    "publish:dry:errors": "cd packages/errors && deno publish --dry-run --allow-dirty",
    "publish:dry:env": "cd packages/env && deno publish --dry-run --allow-dirty",
    "publish:dry:log": "cd packages/log && deno publish --dry-run --allow-dirty",
    "publish:dry:testing": "cd packages/testing && deno publish --dry-run --allow-dirty",
    "publish:dry:http": "cd packages/http && deno publish --dry-run --allow-dirty",
    "publish:dry:cache": "cd packages/cache && deno publish --dry-run --allow-dirty",
    "publish:dry:storage": "cd packages/storage && deno publish --dry-run --allow-dirty",
    "publish:dry:session": "cd packages/session && deno publish --dry-run --allow-dirty",
    "publish:dry:schema": "cd packages/schema && deno publish --dry-run --allow-dirty",
    "publish:dry:migrate": "cd packages/migrate && deno publish --dry-run --allow-dirty",
    "publish:dry:orm": "cd packages/orm && deno publish --dry-run --allow-dirty",
    "publish:dry:jobs": "cd packages/jobs && deno publish --dry-run --allow-dirty"
  }
}
