{
  "workspace": [
    "packages/foundation/*",
    "packages/data/*",
    "packages/web/*",
    "packages/state/*",
    "packages/async/*"
  ],
  "imports": {
    "@std/assert": "jsr:@std/assert@^1",
    "@rootware/errors": "./packages/foundation/errors/mod.ts",
    "@rootware/env": "./packages/foundation/env/mod.ts",
    "@rootware/log": "./packages/foundation/log/mod.ts",
    "@rootware/testing": "./packages/foundation/testing/mod.ts",
    "@rootware/http": "./packages/web/http/mod.ts",
    "@rootware/cache": "./packages/state/cache/mod.ts",
    "@rootware/storage": "./packages/state/storage/mod.ts",
    "@rootware/session": "./packages/state/session/mod.ts",
    "@rootware/schema": "./packages/data/schema/mod.ts",
    "@rootware/migrate": "./packages/data/migrate/mod.ts",
    "@rootware/migrate/postgres": "./packages/data/migrate/postgres/mod.ts",
    "@rootware/orm": "./packages/data/orm/mod.ts",
    "@rootware/orm/postgres": "./packages/data/orm/postgres/mod.ts",
    "@rootware/jobs": "./packages/async/jobs/mod.ts"
  },
  "tasks": {
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "check": "deno check packages/*/*/mod.ts packages/data/orm/postgres/mod.ts packages/data/migrate/postgres/mod.ts",
    "test": "deno test",
    "graph": "deno run -A scripts/check_graph.ts",
    "test:coverage": "deno test --coverage=coverage",
    "coverage:lcov": "deno coverage coverage --lcov > coverage.lcov",
    "ci": "deno task fmt:check && deno task lint && deno task check && deno task graph && deno task test",
    "ci:full": "deno task ci && deno task test:coverage && deno task publish:dry",
    "publish:dry": "deno task publish:dry:errors && deno task publish:dry:env && deno task publish:dry:log && deno task publish:dry:testing && deno task publish:dry:http && deno task publish:dry:cache && deno task publish:dry:storage && deno task publish:dry:session && deno task publish:dry:schema && deno task publish:dry:migrate && deno task publish:dry:orm && deno task publish:dry:jobs",
    "publish:dry:errors": "cd packages/foundation/errors && deno publish --dry-run --allow-dirty",
    "publish:dry:env": "cd packages/foundation/env && deno publish --dry-run --allow-dirty",
    "publish:dry:log": "cd packages/foundation/log && deno publish --dry-run --allow-dirty",
    "publish:dry:testing": "cd packages/foundation/testing && deno publish --dry-run --allow-dirty",
    "publish:dry:http": "cd packages/web/http && deno publish --dry-run --allow-dirty",
    "publish:dry:cache": "cd packages/state/cache && deno publish --dry-run --allow-dirty",
    "publish:dry:storage": "cd packages/state/storage && deno publish --dry-run --allow-dirty",
    "publish:dry:session": "cd packages/state/session && deno publish --dry-run --allow-dirty",
    "publish:dry:schema": "cd packages/data/schema && deno publish --dry-run --allow-dirty",
    "publish:dry:migrate": "cd packages/data/migrate && deno publish --dry-run --allow-dirty",
    "publish:dry:orm": "cd packages/data/orm && deno publish --dry-run --allow-dirty",
    "publish:dry:jobs": "cd packages/async/jobs && deno publish --dry-run --allow-dirty"
  }
}
