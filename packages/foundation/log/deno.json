{
  "name": "@rootware/log",
  "version": "0.8.1",
  "exports": {
    ".": "./mod.ts",
    "./compat/pino": "./compat/pino/mod.ts",
    "./http": "./http/mod.ts"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gilvandovieira/rootware.git"
  },
  "description": "Structured JSON logger for Rootware packages and Deno backends.",
  "keywords": [
    "deno",
    "jsr",
    "rootware",
    "backend",
    "log",
    "logger",
    "logging",
    "structured-logging",
    "json"
  ],
  "publish": {
    "include": [
      "README.md",
      "mod.ts",
      "compat/**/*.ts",
      "http/**/*.ts",
      "deno.json"
    ],
    "exclude": [
      "**/*_test.ts",
      "coverage",
      "*.lcov",
      "*.log",
      "tmp",
      "temp",
      "dist",
      "node_modules"
    ]
  }
}
