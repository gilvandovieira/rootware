{
  "name": "@rootware/orm",
  "version": "0.3.0",
  "exports": {
    ".": "./mod.ts",
    "./postgres": "./postgres/mod.ts"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gilvandovieira/rootware.git"
  },
  "description": "Small typed SQL and ORM primitives for Rootware packages and Deno backends.",
  "keywords": [
    "deno",
    "jsr",
    "rootware",
    "backend",
    "orm",
    "sql",
    "query-builder",
    "database"
  ],
  "publish": {
    "include": [
      "README.md",
      "mod.ts",
      "core/**/*.ts",
      "postgres/**/*.ts",
      "deno.json"
